const std = @import("std");
const log = std.log;
const builtin = @import("builtin");
const client = @import("client_core.zig");

const wl = @cImport({
    @cInclude("wayland-client.h");
});
const xdg = @cImport(@cInclude("xdg-shell-client-protocol.h"));

fn randname(buf: *[6]u8) void {
    var seed: u64 = undefined;
    _ = std.os.linux.getrandom(@ptrCast(&seed), @sizeOf(u64), 0);
    var prng = std.Random.DefaultPrng.init(seed);
    const random = prng.random();
    for (buf) |*b| {
        b.* = random.intRangeAtMost(u8, 'A', 'Z');
    }
}

fn create_shm_file() std.os.linux.fd_t {
    const flags: std.os.linux.O = .{ .ACCMODE = .RDWR, .CREAT = true, .EXCL = true };

    const shm_open = struct {
        extern "c" fn shm_open(name: [*:0]const u8, flag: c_int, mode: std.c.mode_t) c_int;
    }.shm_open;

    var retries: u8 = 100;
    while (retries > 0) : (retries -= 1) {
        var name = "/wl_shm-XXXXXX".*;
        randname(name[8..]);
        const fd = shm_open(
            &name,
            @bitCast(flags), // packed struct -> c_int
            0o600, // mode: octal literal works here
        );
        if (fd >= 0) {
            _ = std.c.shm_unlink(&name);
            return fd;
        }
        if (std.c._errno().* != @intFromEnum(std.posix.E.EXIST)) break;
    }

    return -1;
}

fn allocateShmFile(size: i64) std.os.linux.fd_t {
    const fd = create_shm_file();

    if (fd < 0) return -1;

    var ret: usize = undefined;
    while (true) {
        ret = std.os.linux.ftruncate(fd, size);

        if (ret >= 0 or std.c._errno().* != @intFromEnum(std.posix.E.INTR)) break;
    }

    if (ret < 0) {
        _ = std.os.linux.close(fd);
        return -1;
    }

    return fd;
}

fn wl_buffer_release(
    data: ?*anyopaque,
    wl_buffer: ?*wl.wl_buffer,
) callconv(.c) void {
    _ = data; // autofix
    wl.wl_buffer_destroy(wl_buffer);
}

const wl_buffer_listener: wl.wl_buffer_listener = .{
    .release = wl_buffer_release,
};

fn drawFrame(state: *ClientState) ?*wl.wl_buffer {
    const width: usize = 640;
    const height: usize = 480;
    const stride: usize = width * 4;
    const size: usize = stride * height;

    const fd = allocateShmFile(size);
    if (fd == -1) {
        return null;
    }

    const data = std.os.linux.mmap(
        null,
        size,
        .{ .READ = true, .WRITE = true },
        .{ .TYPE = .SHARED },
        fd,
        0,
    );
    if (data == std.math.maxInt(usize)) {
        _ = std.os.linux.close(fd);
        return null;
    }

    const pool: ?*wl.wl_shm_pool = wl.wl_shm_create_pool(state.wl_shm, fd, size);
    const buffer: ?*wl.wl_buffer = wl.wl_shm_pool_create_buffer(
        pool,
        0,
        width,
        height,
        stride,
        wl.WL_SHM_FORMAT_XRGB8888,
    );
    wl.wl_shm_pool_destroy(pool);
    _ = std.os.linux.close(fd);

    _ = std.os.linux.munmap(@ptrCast(@alignCast(&data)), size);
    _ = wl.wl_buffer_add_listener(buffer, &wl_buffer_listener, null);
    return buffer;
}

const ClientState = struct {
    const Self = @This();

    // Globals
    should_close: bool = false,
    wl_display: ?*wl.wl_display,
    wl_registry: ?*wl.wl_registry,
    wl_shm: ?*wl.wl_shm = null,
    wl_compositor: ?*wl.wl_compositor,
    xdg_wm_base: ?*xdg.xdg_wm_base,

    // Objects
    surface: ?*wl.wl_surface,
    xdg_surface: ?*xdg.xdg_surface,
    xdg_toplevel: ?*xdg.xdg_toplevel,
};

fn xdg_surface_configure(
    data: ?*anyopaque,
    xdg_surface: ?*xdg.xdg_surface,
    serial: u32,
) callconv(.c) void {
    var state: *ClientState = @ptrCast(@alignCast(data));
    xdg.xdg_surface_ack_configure(xdg_surface, serial);

    const buffer = drawFrame(state);
    wl.wl_surface_attach(state.surface, buffer, 0, 0);
    wl.wl_surface_commit(state.surface);
}

const xdg_surface_listener: xdg.xdg_surface_listener = .{
    .configure = xdg_surface_configure,
};

fn xdg_wm_base_ping(
    data: ?*anyopaque,
    xdg_wm_base: ?*xdg.xdg_wm_base,
    serial: u32,
) callconv(.c) void {
    _ = data; // autofix
    xdg.xdg_wm_base_pong(xdg_wm_base, serial);
}

const xdg_wm_base_listener: xdg.xdg_wm_base_listener = .{
    .ping = xdg_wm_base_ping,
};

fn xdg_toplevel_configure(
    data: ?*anyopaque,
    xdg_toplevel: ?*xdg.xdg_toplevel,
    width: i32,
    height: i32,
    states: [*c]xdg.wl_array,
) callconv(.c) void {
    _ = data; // autofix
    _ = xdg_toplevel; // autofix
    _ = width; // autofix
    _ = height; // autofix
    _ = states; // autofix
    // TODO: handle resize later
}

fn xdg_toplevel_close(
    data: ?*anyopaque,
    xdg_toplevel: ?*xdg.xdg_toplevel,
) callconv(.c) void {
    _ = xdg_toplevel; // autofix
    var state: *ClientState = @ptrCast(@alignCast(data));
    state.should_close = true;
}

const xdg_toplevel_listener: xdg.xdg_toplevel_listener = .{
    .configure = xdg_toplevel_configure,
    .close = xdg_toplevel_close,
};

fn registry_global(
    data: ?*anyopaque,
    wl_registry: ?*wl.wl_registry,
    name: u32,
    interface: [*c]const u8,
    version: u32,
) callconv(.c) void {
    _ = version; // autofix

    var state: *ClientState = @ptrCast(@alignCast(data));

    if (std.zig.c_translation.builtins.strcmp(interface, wl.wl_shm_interface.name) == 0) {
        state.wl_shm = @ptrCast(@alignCast(wl.wl_registry_bind(
            wl_registry,
            name,
            &wl.wl_shm_interface,
            1,
        )));
    } else if (std.zig.c_translation.builtins.strcmp(interface, wl.wl_compositor_interface.name) == 0) {
        state.wl_compositor = @ptrCast(@alignCast(wl.wl_registry_bind(
            wl_registry,
            name,
            &wl.wl_compositor_interface,
            4,
        )));
    } else if (std.zig.c_translation.builtins.strcmp(interface, xdg.xdg_wm_base_interface.name) == 0) {
        state.xdg_wm_base = @ptrCast(@alignCast(wl.wl_registry_bind(
            wl_registry,
            name,
            @ptrCast(&xdg.xdg_wm_base_interface),
            1,
        )));

        _ = xdg.xdg_wm_base_add_listener(
            state.xdg_wm_base,
            &xdg_wm_base_listener,
            state,
        );
    }
}

fn registry_global_remove(
    data: ?*anyopaque,
    wl_registry: ?*wl.wl_registry,
    name: u32,
) callconv(.c) void {
    _ = data; // autofix
    _ = wl_registry; // autofix
    _ = name; // autofix
    // This space deliberately left blank
}

const wl_registry_listener: wl.wl_registry_listener = .{
    .global = registry_global,
    .global_remove = registry_global_remove,
};

const WaylandError = error{
    Connection,
};

pub fn main() anyerror!void {
    const display = wl.wl_display_connect(null) orelse {
        log.err("Failed to connect to Wayland display.", .{});
        return WaylandError.Connection;
    };

    const registry = wl.wl_display_get_registry(display) orelse {
        log.err("Failed to get Wayland display registry.", .{});
        return WaylandError.Connection;
    };

    var state: ClientState = .{
        .wl_display = display,
        .wl_registry = registry,
        .wl_compositor = undefined,
        .surface = undefined,
        .xdg_wm_base = undefined,
        .xdg_surface = undefined,
        .xdg_toplevel = undefined,
    };

    _ = wl.wl_registry_add_listener(state.wl_registry, &wl_registry_listener, &state);
    _ = wl.wl_display_roundtrip(state.wl_display);

    state.surface = wl.wl_compositor_create_surface(state.wl_compositor);
    state.xdg_surface = xdg.xdg_wm_base_get_xdg_surface(
        state.xdg_wm_base,
        @ptrCast(state.surface),
    );
    _ = xdg.xdg_surface_add_listener(
        state.xdg_surface,
        &xdg_surface_listener,
        &state,
    );
    state.xdg_toplevel = xdg.xdg_surface_get_toplevel(state.xdg_surface);
    _ = xdg.xdg_toplevel_add_listener(state.xdg_toplevel, &xdg_toplevel_listener, &state);
    xdg.xdg_toplevel_set_title(state.xdg_toplevel, "Example client");
    wl.wl_surface_commit(state.surface);

    while (!state.should_close) {
        if (wl.wl_display_dispatch(state.wl_display) < 0) break;
    }

    log.info("Window closed", .{});
}
